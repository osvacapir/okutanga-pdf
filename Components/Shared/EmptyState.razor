@*
    Estado vazio padronizado: ícone, título, descrição e (opcional) acção.
    Usar quando uma lista/tabela não tem dados, em vez de um <p> solto.
*@

<div class="ol-empty-state @(Tone == EmptyStateTone.Warning ? "ol-empty-state--warn" : null) @AdditionalClass" role="status">
    <div class="ol-empty-state-icon" aria-hidden="true">
        <i class="bi @ResolveIcon()"></i>
    </div>
    <h3 class="ol-empty-state-title">@Title</h3>
    @if (!string.IsNullOrWhiteSpace(Description))
    {
        <p class="ol-empty-state-desc">@Description</p>
    }
    @if (ChildContent is not null)
    {
        <div class="ol-empty-state-actions">@ChildContent</div>
    }
</div>

@code {
    public enum EmptyStateTone
    {
        Neutral,
        Warning,
    }

    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter] public string? Description { get; set; }

    [Parameter] public string? Icon { get; set; }

    [Parameter] public EmptyStateTone Tone { get; set; } = EmptyStateTone.Neutral;

    [Parameter] public string? AdditionalClass { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string ResolveIcon() =>
        string.IsNullOrWhiteSpace(Icon) ? "bi-inbox" : Icon!;
}
