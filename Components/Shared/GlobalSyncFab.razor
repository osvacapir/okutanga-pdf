@implements IDisposable
@inject IAuthService Auth
@inject IGradesSyncService Sync
@inject IAppNotificationService Notifications
@inject NavigationManager Nav
@using Radzen

@if (_visible)
{
    <button type="button"
            class="ol-fab-refresh @(_busy ? "is-busy" : null)"
            disabled="@_busy"
            aria-busy="@_busy"
            title="Sincronizar matrículas e notas com o servidor"
            @onclick="OnClickAsync"
            aria-label="Atualizar dados">
        <span class="ol-fab-icon" aria-hidden="true">
            <svg class="ol-fab-glyph" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" focusable="false">
                <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
                <path d="M3 3v5h5" />
                <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16" />
                <path d="M16 16h5v5" />
            </svg>
        </span>
        @if (_busy)
        {
            <svg class="ol-fab-ring" viewBox="0 0 36 36" aria-hidden="true">
                <circle class="ol-fab-ring-track" cx="18" cy="18" r="16"></circle>
                <circle class="ol-fab-ring-progress" cx="18" cy="18" r="16"></circle>
            </svg>
        }
        <span class="visually-hidden">@(_busy ? "A sincronizar…" : "Sincronizar")</span>
    </button>
}

@code {
    private bool _visible;
    private bool _busy;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        Auth.AuthenticationStateChanged += OnAuthChanged;
        RecomputeVisible();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Auth.InitializeAsync();
        RecomputeVisible();
        StateHasChanged();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        RecomputeVisible();
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnAuthChanged()
    {
        RecomputeVisible();
        _ = InvokeAsync(StateHasChanged);
    }

    private void RecomputeVisible()
    {
        _visible = Auth.IsReady && Auth.IsAuthenticated;
    }

    private async Task OnClickAsync()
    {
        if (_busy)
        {
            return;
        }

        _busy = true;
        StateHasChanged();
        try
        {
            await Auth.InitializeAsync();
            if (!Auth.IsAuthenticated)
            {
                return;
            }

            var outcome = await Sync.RunScheduledSyncAsync(force: true);
            if (outcome.Status == GradesSyncStatus.Completed)
            {
                Notifications.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = "Sincronização concluída",
                    Detail = outcome.DataChanged ? "Foram encontrados dados novos." : "Sem alterações no servidor.",
                    Duration = 2500,
                });
            }
            else if (outcome.Status == GradesSyncStatus.Failed)
            {
                Notifications.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = "Sincronização falhou",
                    Detail = outcome.Message ?? "Não foi possível sincronizar agora. Tente novamente.",
                    Duration = 4500,
                });
            }
        }
        catch (OperationCanceledException)
        {
            // timeout/cancel do HttpClient
            Notifications.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Warning,
                Summary = "Sincronização interrompida",
                Detail = "A rede demorou demasiado a responder. Tente novamente.",
                Duration = 4500,
            });
        }
        catch
        {
            // falhas residuais (ex. assinantes SyncFinished) não devem rebentar o FAB
            Notifications.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Sincronização falhou",
                Detail = "Ocorreu um erro inesperado.",
                Duration = 4500,
            });
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        Auth.AuthenticationStateChanged -= OnAuthChanged;
    }
}
