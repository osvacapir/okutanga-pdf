@implements IDisposable
@inject IConnectivityService ConnectivityService

@if (_showOfflineBanner)
{
    <div class="connection-banner-fixed" role="status" aria-live="polite">
        <div class="connection-banner connection-banner-offline">
            <span class="connection-banner-text">
                <span>Sem ligação — dados em cache. Toque em ⟳ quando tiver rede.</span>
            </span>
        </div>
    </div>
}

@code {
    private const int AutoHideOfflineMs = 4500;

    private bool _showOfflineBanner;
    private bool _lastOnline = true;
    private bool _offlineHintDismissedThisSession;
    private CancellationTokenSource? _autoHideCts;
    private bool _disposed;

    protected override void OnInitialized()
    {
        ConnectivityService.ReachabilityChanged += OnReachabilityChanged;
        Refresh();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && !_disposed)
        {
            Refresh();
            StateHasChanged();
        }
    }

    private void OnReachabilityChanged(object? sender, ConnectivityChangedInfo e)
    {
        _ = SafeInvokeAsync(() =>
        {
            if (_disposed) return;
            Refresh();
            StateHasChanged();
        });
    }

    private void Refresh()
    {
        var online = ConnectivityService.IsOnline;
        if (online)
        {
            CancelAutoHide();
            _offlineHintDismissedThisSession = false;
            _lastOnline = true;
            _showOfflineBanner = false;
            return;
        }

        if (_lastOnline)
        {
            _lastOnline = false;
            _offlineHintDismissedThisSession = false;
            StartAutoHideForOfflineSession();
        }

        _showOfflineBanner = !_offlineHintDismissedThisSession;
    }

    private void StartAutoHideForOfflineSession()
    {
        CancelAutoHide();
        _autoHideCts = new CancellationTokenSource();
        var ct = _autoHideCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(AutoHideOfflineMs, ct).ConfigureAwait(false);
                if (ct.IsCancellationRequested || _disposed) return;
                if (ConnectivityService.IsOnline) return;

                await SafeInvokeAsync(() =>
                {
                    if (_disposed) return;
                    _offlineHintDismissedThisSession = true;
                    _showOfflineBanner = false;
                    StateHasChanged();
                });
            }
            catch (OperationCanceledException)
            {
                // cancelado ao voltar online ou dispose
            }
        });
    }

    private void CancelAutoHide()
    {
        try
        {
            _autoHideCts?.Cancel();
        }
        catch (ObjectDisposedException)
        {
            // ignorar
        }

        _autoHideCts?.Dispose();
        _autoHideCts = null;
    }

    public void Dispose()
    {
        _disposed = true;
        CancelAutoHide();
        ConnectivityService.ReachabilityChanged -= OnReachabilityChanged;
    }

    private async Task SafeInvokeAsync(Action action)
    {
        try
        {
            await InvokeAsync(action);
        }
        catch (InvalidOperationException)
        {
            // Dispatcher/renderer indisponível (Hot Reload / dispose)
        }
    }
}
