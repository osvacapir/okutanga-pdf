@inherits LayoutComponentBase
@using OkutangaPDF.Components.Shared
@inject IAppShellService Shell
@inject IJSRuntime JS

<PdfLaunchListener />

<div class="layout-shell">
    @if (Shell.IsDesktopShell)
    {
        <div class="page layout-desktop-app" id="page-root">
            <DesktopAppShell />

            <main>
                <article class="content">
                    <div class="content-wrapper">
                        @Body
                    </div>
                </article>
            </main>

            <Toaster />
        </div>
    }
    else
    {
        <div class="page layout-mobile-app layout-with-dock" id="page-root">
            <main>
                <Header />

                <article class="content">
                    <div class="content-wrapper">
                        @Body
                    </div>
                </article>
            </main>

            <Toaster />
            <FloatingGlassDock />
        </div>
    }
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("okutangaPdfReader.prewarm");
        }
        catch
        {
            // Motor PDF aquece no primeiro uso.
        }
    }
}
