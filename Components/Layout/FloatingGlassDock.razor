@inject NavigationManager Navigation

<div class="ol-glass-dock-root" aria-label="Navegação principal">
    <div class="ol-glass-dock-pill ol-glass-dock-pill--compact">
        <NavLink class="ol-glass-dock-item"
                 href="/biblioteca"
                 title="Biblioteca"
                 ActiveClass="ol-glass-dock-item--active">
            <i class="bi bi-bookshelf" aria-hidden="true"></i>
            <span class="ol-glass-dock-label">Biblioteca</span>
        </NavLink>
        <NavLink class="ol-glass-dock-item"
                 href="/leitor"
                 title="Leitor"
                 Match="NavLinkMatch.Prefix"
                 ActiveClass="ol-glass-dock-item--active">
            <i class="bi bi-file-earmark-pdf" aria-hidden="true"></i>
            <span class="ol-glass-dock-label">Leitor</span>
        </NavLink>
        <NavLink class="ol-glass-dock-item"
                 href="/definicoes"
                 title="Definições"
                 ActiveClass="ol-glass-dock-item--active">
            <i class="bi bi-gear" aria-hidden="true"></i>
            <span class="ol-glass-dock-label">Definições</span>
        </NavLink>
    </div>
</div>
