@page "/grades"
@implements IDisposable
@inject IAuthService Auth
@inject IGradesLocalStore Store
@inject IGradesSyncService Sync
@using OlondongeApp.Components.Shared
@inject NavigationManager Nav
@using OlondongeApp.Models
@using OlondongeApp.Models.Dtos

<PageTitle>Notas — Olondonge</PageTitle>

@if (!_ready)
{
    <LoadingSkeleton Variant="LoadingSkeleton.LoadingSkeletonVariant.Cards" Items="3" />
}
else if (!Auth.IsAuthenticated)
{
    <p>A redirecionar…</p>
}
else
{
    <div class="ol-grades-header-card">
        <PageHeader Title="Notas"
                    TitleAside="@_titleAsideYear"
                    Subtitle="@_syncHint"
                    ShowBack="false" />
    </div>

    @if (_totalEnrolmentsCached == 0)
    {
        <EmptyState Title="Sem matrículas em cache"
                    Description="Sincronize com ligação à Internet para descarregar as suas matrículas e notas."
                    Icon="bi-cloud-arrow-down"
                    Tone="EmptyState.EmptyStateTone.Warning">
            <button type="button" class="btn btn-primary" disabled="@_syncing" @onclick="OnSyncNowAsync">
                @(_syncing ? "A sincronizar…" : "Sincronizar agora")
            </button>
        </EmptyState>
    }
    else if (_enrolments.Count == 0)
    {
        <EmptyState Title="Sem matrícula no ano lectivo actual"
                    Description="Pode não estar definida na escola ou ainda não foi sincronizada. Consulte anos anteriores no histórico."
                    Icon="bi-journal-x"
                    Tone="EmptyState.EmptyStateTone.Warning">
            <button type="button" class="btn btn-outline-primary" disabled="@_syncing" @onclick="OnSyncNowAsync">
                @(_syncing ? "A sincronizar…" : "Sincronizar agora")
            </button>
            <a class="btn btn-link" href="/historico-academico">Histórico académico</a>
        </EmptyState>
    }
    else
    {
        <p class="ol-muted mb-2"><a href="/historico-academico">Ver histórico académico (outros anos)</a></p>
        <div class="ol-filter-card">
            <div class="ol-filter-header">
                <strong>Filtros</strong>
            </div>
            <div class="ol-filter-grid ol-filter-grid--grades-pair">
                <div class="ol-filter-item">
                    <label>Matrícula</label>
                    <select class="ol-input" @key="_matriculaSelectKey" value="@_selectedMatriculaId" @onchange="OnMatriculaSelectChange">
                        @foreach (var e in _enrolments)
                        {
                            var optTitle = EnrolmentDisplayFormatter.FormatMatriculaOptionTitle(e) ?? EnrolmentDisplayFormatter.FormatMatriculaSelectLabel(e);
                            <option value="@e.MatriculaId" title="@optTitle">@EnrolmentDisplayFormatter.FormatMatriculaSelectLabel(e)</option>
                        }
                    </select>
                </div>
                <div class="ol-filter-item">
                    <label>Trimestre</label>
                    <select class="ol-input" value="@_selectedPeriodoId" @onchange="OnPeriodSelectChange">
                        @foreach (var p in _periods)
                        {
                            <option value="@p.PeriodoId">@(p.PeriodoName ?? ("Período " + p.PeriodoId))</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <GradesBookBody Grades="_grades" />
    }
}

@code {
    private bool _ready;
    private bool _syncing;
    private string _syncHint = string.Empty;
    private List<EnrolmentDto> _enrolments = new();
    private int _totalEnrolmentsCached;
    private List<(int PeriodoId, string? PeriodoName)> _periods = new();
    private List<GradeLineDto> _grades = new();
    private int _selectedMatriculaId;
    private int _selectedPeriodoId;
    private int _matriculaSelectKey;
    private string? _titleAsideYear;
    private async Task OnSyncNowAsync()
    {
        if (_syncing) return;
        _syncing = true;
        StateHasChanged();
        try
        {
            await Sync.RunScheduledSyncAsync(force: true);
        }
        catch
        {
            // SyncFinished ainda dispara em caso de falha controlada.
        }
        finally
        {
            _syncing = false;
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (!Auth.IsAuthenticated)
        {
            Nav.NavigateTo("/login", true);
            return;
        }

        await LoadLocalAsync();
        await UpdateSyncHintAsync();
        _ready = true;
        Auth.AuthenticationStateChanged += OnAuthChanged;
        Sync.SyncFinished += OnSyncFinished;
    }

    private void OnAuthChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await Auth.InitializeAsync();
            if (!Auth.IsAuthenticated)
            {
                Nav.NavigateTo("/login", true);
            }
        });
    }

    public void Dispose()
    {
        Auth.AuthenticationStateChanged -= OnAuthChanged;
        Sync.SyncFinished -= OnSyncFinished;
    }

    private void OnSyncFinished(GradesSyncOutcome outcome)
    {
        _ = InvokeAsync(async () =>
        {
            await LoadLocalAsync();
            await UpdateSyncHintAsync();
            if (outcome.Status == GradesSyncStatus.Failed && !string.IsNullOrEmpty(outcome.Message))
            {
                _syncHint = outcome.Message;
            }

            StateHasChanged();
        });
    }

    private async Task LoadLocalAsync()
    {
        var all = (await Store.GetEnrolmentsAsync()).ToList();
        _totalEnrolmentsCached = all.Count;
        _enrolments = all
            .Where(e => e.IsCurrentAnoLectivo)
            .OrderByDescending(x => x.MatriculaId)
            .ToList();
        if (_enrolments.All(e => e.MatriculaId != _selectedMatriculaId))
        {
            _selectedMatriculaId = 0;
            _selectedPeriodoId = 0;
        }

        if (_enrolments.Count > 0 && _selectedMatriculaId == 0)
        {
            _selectedMatriculaId = _enrolments[0].MatriculaId;
        }

        if (_selectedMatriculaId != 0)
        {
            _periods = (await Store.GetPeriodsAsync(_selectedMatriculaId))
                .OrderByDescending(x => x.PeriodoId)
                .ToList();
            if (_periods.Count > 0 && _selectedPeriodoId == 0)
            {
                _selectedPeriodoId = _periods[0].PeriodoId;
            }
        }
        else
        {
            _periods = new List<(int PeriodoId, string? PeriodoName)>();
            _selectedPeriodoId = 0;
        }

        await LoadGradesForSelectionAsync();
        RefreshTitleAsideYear();
        _matriculaSelectKey++;
    }

    private void RefreshTitleAsideYear()
    {
        var e = _enrolments.FirstOrDefault(x => x.MatriculaId == _selectedMatriculaId);
        _titleAsideYear = string.IsNullOrWhiteSpace(e?.AnoLectivoName) ? null : e!.AnoLectivoName!.Trim();
    }

    private async Task OnMatriculaSelectChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedMatriculaId = id;
            await OnMatriculaChangedAsync();
        }
    }

    private async Task OnPeriodSelectChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedPeriodoId = id;
            await LoadGradesForSelectionAsync();
        }
    }

    private async Task OnMatriculaChangedAsync()
    {
        _periods = (await Store.GetPeriodsAsync(_selectedMatriculaId))
            .OrderByDescending(x => x.PeriodoId)
            .ToList();
        _selectedPeriodoId = _periods.Count > 0 ? _periods[0].PeriodoId : 0;
        await LoadGradesForSelectionAsync();
        RefreshTitleAsideYear();
    }

    private async Task LoadGradesForSelectionAsync()
    {
        if (_selectedMatriculaId == 0 || _selectedPeriodoId == 0)
        {
            _grades = new List<GradeLineDto>();
            return;
        }

        _grades = (await Store.GetGradesAsync(_selectedMatriculaId, _selectedPeriodoId)).ToList();
    }

    private async Task UpdateSyncHintAsync()
    {
        var iso = await Store.GetMetaAsync("last_full_sync_utc");
        if (string.IsNullOrEmpty(iso))
        {
            _syncHint = "Ainda não actualizado.";
            return;
        }

        if (DateTime.TryParse(iso, null, System.Globalization.DateTimeStyles.RoundtripKind, out var utc))
        {
            _syncHint = FormatActualizadoHa(utc);
        }
        else
        {
            _syncHint = "Actualizado: data desconhecida.";
        }
    }

    /// <summary>Texto tipo diffForHumans (UTC da meta vs agora em UTC).</summary>
    private static string FormatActualizadoHa(DateTime syncUtc)
    {
        var now = DateTime.UtcNow;
        var elapsed = now - syncUtc;
        if (elapsed < TimeSpan.Zero)
        {
            return "Actualizado agora.";
        }

        if (elapsed < TimeSpan.FromSeconds(45))
        {
            return "Actualizado agora.";
        }

        if (elapsed < TimeSpan.FromMinutes(1))
        {
            return "Actualizado há menos de um minuto.";
        }

        var minutes = (int)elapsed.TotalMinutes;
        if (minutes < 60)
        {
            return minutes == 1
                ? "Actualizado há 1 minuto."
                : $"Actualizado há {minutes} minutos.";
        }

        var hours = (int)elapsed.TotalHours;
        if (hours < 24)
        {
            return hours == 1
                ? "Actualizado há 1 hora."
                : $"Actualizado há {hours} horas.";
        }

        var days = (int)elapsed.TotalDays;
        return days == 1
            ? "Actualizado há 1 dia."
            : $"Actualizado há {days} dias.";
    }

}
