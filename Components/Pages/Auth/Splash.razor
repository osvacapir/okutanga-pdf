@page "/"
@layout OlondongeApp.Components.Layout.EmptyLayout
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILogger<Splash> Logger

<PageTitle>Carregando - Olondonge</PageTitle>

<div class="splash-container">
    <div class="splash-content">
        <div class="splash-logo">
            <BrandLogoImg Alt="Logo Olondonge"
                          Loading="eager"
                          OnImageLoaded="OnImageLoaded"
                          OnAllCandidatesFailed="OnAllLogoFormatsFailed" />
            <div class="logo-pulse"></div>
        </div>

        <h1 class="splash-title">Olondonge</h1>
        <p class="splash-subtitle">Estudante</p>

        <div class="loading-container">
            <div class="spinner"></div>
            <p class="loading-text">@loadingMessage</p>
        </div>

        <div class="version-info">
            <small>Versão 1.0.0 · Zetabyte · vosikola.com</small>
        </div>
    </div>
</div>

@code {
    private string loadingMessage = "A carregar...";
    private bool imageLoaded = false;
    private bool navigationStarted = false;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await Task.Delay(2000);

        if (!imageLoaded)
        {
            Logger.LogWarning("Imagem não carregou no tempo esperado, continuando...");
        }

        await CheckAuthenticationAndNavigate();
    }

    private Task OnImageLoaded()
    {
        if (!imageLoaded)
        {
            imageLoaded = true;
            Logger.LogInformation("Logo carregado com sucesso na página Splash");
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    private Task OnAllLogoFormatsFailed()
    {
        Logger.LogWarning("Não foi possível carregar nenhum ficheiro de logo em wwwroot/images.");
        imageLoaded = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task CheckAuthenticationAndNavigate()
    {
        if (navigationStarted) return;
        navigationStarted = true;

        try
        {
            loadingMessage = "A verificar sessão...";
            StateHasChanged();

            await AuthService.InitializeAsync();
            var isAuthenticated = AuthService.IsAuthenticated;

            if (isAuthenticated)
            {
                Logger.LogInformation("Utilizador autenticado, redirecionando para o painel inicial...");
                loadingMessage = "Bem-vindo de volta!";
                StateHasChanged();
                await Task.Delay(500);
                Navigation.NavigateTo("/home", replace: true);
            }
            else
            {
                Logger.LogInformation("Utilizador não autenticado, redirecionando para login...");
                loadingMessage = "A redirecionar...";
                StateHasChanged();
                await Task.Delay(500);
                Navigation.NavigateTo("/login", replace: true);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Erro ao verificar autenticação");
            loadingMessage = "Erro ao carregar. A redirecionar...";
            StateHasChanged();
            await Task.Delay(1000);
            Navigation.NavigateTo("/login", replace: true);
        }
    }
}

