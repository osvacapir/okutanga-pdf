@page "/"
@layout OkutangaPDF.Components.Layout.EmptyLayout
@inject NavigationManager Navigation
@inject IIncomingPdfService IncomingPdf
@inject ILogger<Splash> Logger

<PageTitle>@AppPublisherInfo.AppName</PageTitle>

<div class="splash-container">
    <div class="splash-content">
        <div class="splash-logo">
            <BrandLogoImg Alt="@($"Logo {AppPublisherInfo.AppName}")" Loading="eager" />
            <div class="logo-pulse"></div>
        </div>

        <h1 class="splash-title">@AppPublisherInfo.AppName</h1>
        <p class="splash-subtitle">Leitor PDF multiplataforma</p>

        <div class="loading-container">
            <div class="spinner"></div>
            <p class="loading-text">@loadingMessage</p>
        </div>
    </div>
</div>

@code {
    private string loadingMessage = "A carregar…";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await Task.Delay(150);

        try
        {
            if (IncomingPdfBridge.HasBridgePending)
            {
                loadingMessage = "A importar PDF…";
                StateHasChanged();
                await IncomingPdfBridge.FlushToServiceAsync(IncomingPdf);
            }

            var pending = await IncomingPdf.ConsumePendingAsync();
            if (pending is not null)
            {
                Navigation.NavigateTo($"/leitor/{pending.Id}", replace: true);
                return;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Falha ao processar PDF pendente");
        }

        Navigation.NavigateTo("/biblioteca", replace: true);
    }
}
